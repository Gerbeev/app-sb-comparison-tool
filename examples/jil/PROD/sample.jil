insert_job: JOB_A
job_type: c
machine: machine01
calendar: BUSINESS_DAYS
command: /app/job_a.sh ${RUN_DATE}

insert_job: JOB_B
job_type: c
machine: machine01
condition: s(JOB_A)
command: /app/job_b.sh

insert_job: BOX_MAIN
job_type: b

insert_job: JOB_C
job_type: c
box_name: BOX_MAIN
condition: d(JOB_B)
machine: machine02
command: /app/job_c.sh

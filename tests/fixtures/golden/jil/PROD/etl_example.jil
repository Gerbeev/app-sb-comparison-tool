insert_job: ETL
job_type: b

insert_job: EXTRACT
job_type: c
box_name: ETL
command: /app/extract.sh

insert_job: TRANSFORM
job_type: c
box_name: ETL
condition: s(EXTRACT)
command: /app/transform.sh

insert_job: LOAD
job_type: c
box_name: ETL
condition: s(TRANSFORM)
command: /app/load.sh

insert_job: REPORTING
job_type: b

insert_job: BUILD_REPORT
job_type: c
box_name: REPORTING
condition: s(ETL)
command: /app/build_report.sh

insert_job: PUBLISH
job_type: c
box_name: REPORTING
condition: s(BUILD_REPORT)
command: /app/publish.sh

insert_job: ARCHIVE
job_type: b

insert_job: COPY_FILES
job_type: c
box_name: ARCHIVE
condition: s(LOAD)
command: /app/copy_files.sh
